# Copy this file to `.env` and set the providers you want to use.
# Default flow is now `nano_banana` (Gemini-first, speed oriented).
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL_ID=gemini-2.5-flash-image
GEMINI_FAST_MODEL=gemini-2.5-flash-image
GEMINI_REFINE_MODEL=gemini-2.5-flash-image
GEMINI_HERO_MODEL=gemini-3-pro-image-preview
GEMINI_FALLBACK_MODEL=gemini-3.1-flash-image-preview

# Optional providers for alternative profiles / hero rendering.
FAL_KEY=YOUR_FAL_KEY_HERE
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
FAL_FAST_DRAFT_MODEL=fal-ai/flux/schnell
FAL_QUALITY_REFINE_MODEL=fal-ai/flux/dev
OPENAI_HERO_MODEL=gpt-image-1
