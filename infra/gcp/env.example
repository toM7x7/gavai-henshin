# Cloud Run API
NEW_ROUTE_ENV=dev
NEW_ROUTE_PROJECT_ID=gavai-henshin-dev
NEW_ROUTE_CANONICAL_CONFIG=config/new-route.canonical.json

# Cloud SQL PostgreSQL
CLOUD_SQL_INSTANCE_CONNECTION_NAME=project:region:gavai-henshin-sql
DATABASE_URL=postgresql://gavai_api:CHANGE_ME@localhost:5432/gavai_henshin

# GCS artifact bucket
GCS_ARTIFACT_BUCKET=gavai-henshin-artifacts-dev
GCS_PUBLIC_BASE_URL=https://storage.googleapis.com/gavai-henshin-artifacts-dev

# Firebase / Firestore live state
FIREBASE_PROJECT_ID=gavai-henshin-dev
FIRESTORE_LIVE_STATE_PREFIX=dev

# Auth boundary
FIREBASE_AUTH_AUDIENCE=gavai-henshin
SERVICE_ACCOUNT_EMAIL=gavai-api@gavai-henshin-dev.iam.gserviceaccount.com
