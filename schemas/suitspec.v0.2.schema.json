{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gavai-henshin.local/schema/suitspec.v0.2.schema.json",
  "title": "SuitSpec v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "suit_id",
    "style_tags",
    "modules",
    "palette",
    "blueprint",
    "emblem",
    "effects",
    "text",
    "generation"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.2"
    },
    "suit_id": {
      "type": "string",
      "pattern": "^VDA-[A-Z0-9]+-[A-Z0-9]+-[0-9]{2}-[0-9]{4}$"
    },
    "approval_id": {
      "type": "string",
      "pattern": "^APV-[0-9]{8}$"
    },
    "morphotype_id": {
      "type": "string",
      "pattern": "^MTP-[0-9]{8}$"
    },
    "oath": {
      "type": "string",
      "enum": [
        "NO_OMISSION",
        "NO_FABRICATION",
        "SEAL_INTACT",
        "AUDIT_READY",
        "REFUSAL_ACCEPTED",
        "NC_OBSERVED",
        "POSTED_OBEYED",
        "CLEARANCE_RESPECT",
        "PROTOCOL_COMPLETE",
        "INTEGRITY_FIRST"
      ]
    },
    "style_tags": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 32
      }
    },
    "operator_profile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "protect_archetype": {
          "type": "string",
          "minLength": 1
        },
        "temperament_bias": {
          "type": "string",
          "minLength": 1
        },
        "color_mood": {
          "type": "string",
          "minLength": 1
        },
        "note": {
          "type": "string"
        }
      }
    },
    "fit_contract": {
      "$ref": "#/$defs/fitContract"
    },
    "texture_fallback": {
      "$ref": "#/$defs/textureFallback"
    },
    "modules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "helmet",
        "chest",
        "back"
      ],
      "properties": {
        "helmet": {
          "$ref": "#/$defs/module"
        },
        "chest": {
          "$ref": "#/$defs/module"
        },
        "back": {
          "$ref": "#/$defs/module"
        },
        "left_shoulder": {
          "$ref": "#/$defs/module"
        },
        "right_shoulder": {
          "$ref": "#/$defs/module"
        },
        "left_upperarm": {
          "$ref": "#/$defs/module"
        },
        "right_upperarm": {
          "$ref": "#/$defs/module"
        },
        "left_forearm": {
          "$ref": "#/$defs/module"
        },
        "right_forearm": {
          "$ref": "#/$defs/module"
        },
        "waist": {
          "$ref": "#/$defs/module"
        },
        "left_thigh": {
          "$ref": "#/$defs/module"
        },
        "right_thigh": {
          "$ref": "#/$defs/module"
        },
        "left_shin": {
          "$ref": "#/$defs/module"
        },
        "right_shin": {
          "$ref": "#/$defs/module"
        },
        "left_boot": {
          "$ref": "#/$defs/module"
        },
        "right_boot": {
          "$ref": "#/$defs/module"
        },
        "left_hand": {
          "$ref": "#/$defs/module"
        },
        "right_hand": {
          "$ref": "#/$defs/module"
        }
      }
    },
    "palette": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary",
        "secondary",
        "emissive"
      ],
      "properties": {
        "primary": {
          "$ref": "#/$defs/colorHex"
        },
        "secondary": {
          "$ref": "#/$defs/colorHex"
        },
        "emissive": {
          "$ref": "#/$defs/colorHex"
        }
      }
    },
    "blueprint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "image_path",
        "projection_mode"
      ],
      "properties": {
        "image_path": {
          "type": "string",
          "minLength": 1
        },
        "projection_mode": {
          "type": "string",
          "enum": [
            "decal",
            "projector",
            "triplanar"
          ]
        }
      }
    },
    "emblem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "image_path",
        "placement"
      ],
      "properties": {
        "image_path": {
          "type": "string",
          "minLength": 1
        },
        "placement": {
          "type": "string",
          "enum": [
            "chest",
            "left_shoulder",
            "right_shoulder",
            "back",
            "helmet"
          ]
        }
      }
    },
    "effects": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deposition_seconds",
        "particle_density",
        "wire_to_metal_curve"
      ],
      "properties": {
        "deposition_seconds": {
          "type": "number",
          "minimum": 0.1,
          "maximum": 60
        },
        "particle_density": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "wire_to_metal_curve": {
          "type": "string",
          "enum": [
            "linear",
            "ease_in",
            "ease_out",
            "ease_in_out"
          ]
        }
      }
    },
    "text": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deposition_log_lines"
      ],
      "properties": {
        "deposition_log_lines": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          }
        },
        "callout": {
          "type": "string",
          "maxLength": 120
        }
      }
    },
    "generation": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "model_id",
        "prompt"
      ],
      "properties": {
        "model_id": {
          "type": "string",
          "minLength": 1
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "seed": {
          "type": "integer",
          "minimum": 0
        },
        "part_prompts": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  },
  "$defs": {
    "colorHex": {
      "type": "string",
      "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{8})$"
    },
    "fitContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "module_fit_stage",
        "module_fit_space",
        "authoring_baseline_ref",
        "runtime_policy"
      ],
      "properties": {
        "module_fit_stage": {
          "type": "string",
          "enum": [
            "authoring_baseline",
            "calibrated_body_fit",
            "runtime_override"
          ]
        },
        "module_fit_space": {
          "type": "string",
          "enum": [
            "body_sim_segment",
            "vrm_anchor_local",
            "viewer_runtime"
          ]
        },
        "authoring_baseline_ref": {
          "type": "string",
          "minLength": 1
        },
        "runtime_policy": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "textureFallback": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "source"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "palette_material",
            "none"
          ]
        },
        "source": {
          "type": "string",
          "enum": [
            "palette",
            "part_debug_color"
          ]
        },
        "reason": {
          "type": "string",
          "maxLength": 240
        }
      }
    },
    "module": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "asset_ref"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "asset_ref": {
          "type": "string",
          "minLength": 1
        },
        "material_ref": {
          "type": "string",
          "minLength": 1
        },
        "texture_path": {
          "type": "string",
          "minLength": 1
        },
        "attachment_slot": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "fit": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "shape": {
              "type": "string",
              "enum": [
                "box",
                "sphere",
                "cylinder"
              ]
            },
            "source": {
              "type": "string",
              "enum": [
                "chest_core",
                "left_upperarm",
                "right_upperarm",
                "left_forearm",
                "right_forearm",
                "left_thigh",
                "right_thigh",
                "left_shin",
                "right_shin",
                "left_hand",
                "right_hand"
              ]
            },
            "attach": {
              "type": "string",
              "enum": [
                "start",
                "center",
                "end"
              ]
            },
            "offsetY": {
              "type": "number"
            },
            "zOffset": {
              "type": "number"
            },
            "scale": {
              "type": "array",
              "minItems": 3,
              "maxItems": 3,
              "items": {
                "type": "number"
              }
            },
            "follow": {
              "type": "array",
              "minItems": 3,
              "maxItems": 3,
              "items": {
                "type": "number"
              }
            },
            "minScale": {
              "type": "array",
              "minItems": 3,
              "maxItems": 3,
              "items": {
                "type": "number"
              }
            }
          }
        },
        "vrm_anchor": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "bone": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64
            },
            "offset": {
              "type": "array",
              "minItems": 3,
              "maxItems": 3,
              "items": {
                "type": "number"
              }
            },
            "rotation": {
              "type": "array",
              "minItems": 3,
              "maxItems": 3,
              "items": {
                "type": "number"
              }
            },
            "scale": {
              "type": "array",
              "minItems": 3,
              "maxItems": 3,
              "items": {
                "type": "number",
                "minimum": 0.01
              }
            }
          }
        },
        "generation_prompt": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string",
          "maxLength": 200
        }
      }
    }
  }
}
