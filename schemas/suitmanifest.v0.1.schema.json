{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gavai-henshin.local/schema/suitmanifest.v0.1.schema.json",
  "title": "SuitManifest v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "manifest_id",
    "suit_id",
    "source",
    "status",
    "parts",
    "palette",
    "effects"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1"
    },
    "manifest_id": {
      "$ref": "#/$defs/manifestId"
    },
    "suit_id": {
      "$ref": "#/$defs/suitId"
    },
    "approval_id": {
      "$ref": "#/$defs/approvalId"
    },
    "morphotype_id": {
      "$ref": "#/$defs/morphotypeId"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "suitspec_schema_version",
        "suitspec_id"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "suitspec_projection"
          ]
        },
        "suitspec_schema_version": {
          "type": "string",
          "const": "0.2"
        },
        "suitspec_id": {
          "$ref": "#/$defs/suitId"
        },
        "projection_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 32
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "DRAFT",
        "READY",
        "ACTIVE",
        "RETIRED"
      ]
    },
    "runtime_targets": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "web_preview",
          "playcanvas",
          "quest",
          "replay"
        ]
      }
    },
    "fit_contract": {
      "$ref": "#/$defs/fitContract"
    },
    "texture_fallback": {
      "$ref": "#/$defs/textureFallback"
    },
    "parts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "helmet",
        "chest",
        "back"
      ],
      "properties": {
        "helmet": {
          "$ref": "#/$defs/part"
        },
        "chest": {
          "$ref": "#/$defs/part"
        },
        "back": {
          "$ref": "#/$defs/part"
        },
        "left_shoulder": {
          "$ref": "#/$defs/part"
        },
        "right_shoulder": {
          "$ref": "#/$defs/part"
        },
        "left_upperarm": {
          "$ref": "#/$defs/part"
        },
        "right_upperarm": {
          "$ref": "#/$defs/part"
        },
        "left_forearm": {
          "$ref": "#/$defs/part"
        },
        "right_forearm": {
          "$ref": "#/$defs/part"
        },
        "waist": {
          "$ref": "#/$defs/part"
        },
        "left_thigh": {
          "$ref": "#/$defs/part"
        },
        "right_thigh": {
          "$ref": "#/$defs/part"
        },
        "left_shin": {
          "$ref": "#/$defs/part"
        },
        "right_shin": {
          "$ref": "#/$defs/part"
        },
        "left_boot": {
          "$ref": "#/$defs/part"
        },
        "right_boot": {
          "$ref": "#/$defs/part"
        },
        "left_hand": {
          "$ref": "#/$defs/part"
        },
        "right_hand": {
          "$ref": "#/$defs/part"
        }
      }
    },
    "palette": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary",
        "secondary",
        "emissive"
      ],
      "properties": {
        "primary": {
          "$ref": "#/$defs/colorHex"
        },
        "secondary": {
          "$ref": "#/$defs/colorHex"
        },
        "emissive": {
          "$ref": "#/$defs/colorHex"
        }
      }
    },
    "blueprint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "image_path",
        "projection_mode"
      ],
      "properties": {
        "image_path": {
          "type": "string",
          "minLength": 1
        },
        "projection_mode": {
          "type": "string",
          "enum": [
            "decal",
            "projector",
            "triplanar"
          ]
        }
      }
    },
    "emblem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "image_path",
        "placement"
      ],
      "properties": {
        "image_path": {
          "type": "string",
          "minLength": 1
        },
        "placement": {
          "type": "string",
          "enum": [
            "chest",
            "left_shoulder",
            "right_shoulder",
            "back",
            "helmet"
          ]
        }
      }
    },
    "effects": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deposition_seconds",
        "particle_density",
        "wire_to_metal_curve"
      ],
      "properties": {
        "deposition_seconds": {
          "type": "number",
          "minimum": 0.1,
          "maximum": 60
        },
        "particle_density": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "wire_to_metal_curve": {
          "type": "string",
          "enum": [
            "linear",
            "ease_in",
            "ease_out",
            "ease_in_out"
          ]
        }
      }
    },
    "text": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "deposition_log_lines": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          }
        },
        "callout": {
          "type": "string",
          "maxLength": 120
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "manifest_path": {
          "type": "string",
          "minLength": 1
        },
        "preview_image_path": {
          "type": "string",
          "minLength": 1
        },
        "glb_path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  },
  "$defs": {
    "manifestId": {
      "type": "string",
      "pattern": "^MNF-[0-9]{8}-[A-Z0-9]{4}$"
    },
    "suitId": {
      "type": "string",
      "pattern": "^VDA-[A-Z0-9]+-[A-Z0-9]+-[0-9]{2}-[0-9]{4}$"
    },
    "approvalId": {
      "type": "string",
      "pattern": "^APV-[0-9]{8}$"
    },
    "morphotypeId": {
      "type": "string",
      "pattern": "^MTP-[0-9]{8}$"
    },
    "colorHex": {
      "type": "string",
      "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{8})$"
    },
    "fitContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "module_fit_stage",
        "module_fit_space",
        "authoring_baseline_ref",
        "runtime_policy"
      ],
      "properties": {
        "module_fit_stage": {
          "type": "string",
          "enum": [
            "authoring_baseline",
            "calibrated_body_fit",
            "runtime_override"
          ]
        },
        "module_fit_space": {
          "type": "string",
          "enum": [
            "body_sim_segment",
            "vrm_anchor_local",
            "viewer_runtime"
          ]
        },
        "authoring_baseline_ref": {
          "type": "string",
          "minLength": 1
        },
        "runtime_policy": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "textureFallback": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "source"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "palette_material",
            "none"
          ]
        },
        "source": {
          "type": "string",
          "enum": [
            "palette",
            "part_debug_color"
          ]
        },
        "reason": {
          "type": "string",
          "maxLength": 240
        }
      }
    },
    "part": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "asset_ref"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "asset_ref": {
          "type": "string",
          "minLength": 1
        },
        "catalog_part_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_.-]*$"
        },
        "material_ref": {
          "type": "string",
          "minLength": 1
        },
        "texture_path": {
          "type": "string",
          "minLength": 1
        },
        "attachment_slot": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "fit": {
          "$ref": "#/$defs/fit"
        },
        "vrm_anchor": {
          "$ref": "#/$defs/vrmAnchor"
        },
        "runtime_flags": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "visible": {
              "type": "boolean"
            },
            "collision_enabled": {
              "type": "boolean"
            },
            "tracking_locked": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "fit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "shape": {
          "type": "string",
          "enum": [
            "box",
            "sphere",
            "cylinder"
          ]
        },
        "source": {
          "type": "string",
          "enum": [
            "chest_core",
            "left_upperarm",
            "right_upperarm",
            "left_forearm",
            "right_forearm",
            "left_thigh",
            "right_thigh",
            "left_shin",
            "right_shin",
            "left_hand",
            "right_hand"
          ]
        },
        "attach": {
          "type": "string",
          "enum": [
            "start",
            "center",
            "end"
          ]
        },
        "offsetY": {
          "type": "number"
        },
        "zOffset": {
          "type": "number"
        },
        "scale": {
          "$ref": "#/$defs/vector3"
        },
        "follow": {
          "$ref": "#/$defs/vector3"
        },
        "minScale": {
          "$ref": "#/$defs/vector3"
        }
      }
    },
    "vrmAnchor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bone": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "offset": {
          "$ref": "#/$defs/vector3"
        },
        "rotation": {
          "$ref": "#/$defs/vector3"
        },
        "scale": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "type": "number",
            "minimum": 0.01
          }
        }
      }
    },
    "vector3": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "number"
      }
    }
  }
}
