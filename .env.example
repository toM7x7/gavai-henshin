# Copy this file to `.env` and set the providers you want to use.
# Web Forge texture generation is fixed to `nano_banana` (Gemini-first).
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL_ID=gemini-2.5-flash-image
GEMINI_FAST_MODEL=gemini-2.5-flash-image
GEMINI_REFINE_MODEL=gemini-2.5-flash-image
GEMINI_HERO_MODEL=gemini-3-pro-image-preview
GEMINI_FALLBACK_MODEL=gemini-3.1-flash-image-preview

# Optional legacy providers; Web Forge texture generation does not use these.
FAL_KEY=YOUR_FAL_KEY_HERE
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
FAL_FAST_DRAFT_MODEL=fal-ai/flux/schnell
FAL_QUALITY_REFINE_MODEL=fal-ai/flux/dev
OPENAI_HERO_MODEL=gpt-image-1

# Sakura AI Engine audio bridge.
SAKURA_AI_ENGINE_TOKEN=YOUR_SAKURA_AI_ENGINE_TOKEN_HERE
SAKURA_AI_ENGINE_BASE_URL=https://api.ai.sakura.ad.jp/v1
SAKURA_WHISPER_MODEL=whisper-large-v3-turbo
SAKURA_TTS_MODEL=zundamon
SAKURA_TTS_VOICE=normal
SAKURA_TTS_FORMAT=wav
VOICE_TRIGGER_PHRASE=生成

# Quest 3 same-LAN HTTPS dev server.
# Required for Quest Browser microphone/WebXR when not using localhost.
QUEST_HOST=0.0.0.0
QUEST_PORT=5173
QUEST_API_TARGET=http://127.0.0.1:8010
QUEST_HTTPS_PFX=config/quest-lan.pfx
QUEST_HTTPS_PFX_PASSWORD=quest-local
QUEST_HTTPS_CERT=config/quest-lan.pem
QUEST_HTTPS_KEY=config/quest-lan-key.pem
