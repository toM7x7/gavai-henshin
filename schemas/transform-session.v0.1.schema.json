{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gavai-henshin.local/schema/transform-session.v0.1.schema.json",
  "title": "TransformSession v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "session_id",
    "manifest_id",
    "state",
    "started_at",
    "events"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1"
    },
    "session_id": {
      "$ref": "#/$defs/sessionId"
    },
    "manifest_id": {
      "$ref": "#/$defs/manifestId"
    },
    "suit_id": {
      "$ref": "#/$defs/suitId"
    },
    "operator_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 96
    },
    "device_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 96
    },
    "tracking_source": {
      "type": "string",
      "enum": [
        "manual",
        "mocopi",
        "webcam",
        "quest",
        "iw_sdk"
      ]
    },
    "state": {
      "$ref": "#/$defs/transformState"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "refusal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reason",
        "occurred_at"
      ],
      "properties": {
        "reason": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "occurred_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/transformEvent"
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "replay_script_path": {
          "type": "string",
          "minLength": 1
        },
        "body_sim_path": {
          "type": "string",
          "minLength": 1
        },
        "voice_audio_path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  },
  "$defs": {
    "sessionId": {
      "type": "string",
      "pattern": "^S-[A-Z0-9][A-Z0-9-]{2,63}$"
    },
    "manifestId": {
      "type": "string",
      "pattern": "^MNF-[0-9]{8}-[A-Z0-9]{4}$"
    },
    "suitId": {
      "type": "string",
      "pattern": "^VDA-[A-Z0-9]+-[A-Z0-9]+-[0-9]{2}-[0-9]{4}$"
    },
    "eventId": {
      "type": "string",
      "pattern": "^EVT-[0-9]{8}-[A-Z0-9]{6}$"
    },
    "transformState": {
      "type": "string",
      "enum": [
        "IDLE",
        "POSTED",
        "FIT_AUDIT",
        "MORPHOTYPE_LOCKED",
        "DESIGN_ISSUED",
        "DRY_FIT_SIM",
        "TRY_ON",
        "APPROVAL_PENDING",
        "APPROVED",
        "DEPOSITION",
        "SEALING",
        "ACTIVE",
        "ARCHIVED",
        "REFUSED"
      ]
    },
    "transformEventType": {
      "type": "string",
      "enum": [
        "SESSION_CREATED",
        "TRIGGER_DETECTED",
        "VOICE_CAPTURED",
        "TRACKING_FRAME_BATCH",
        "STATE_TRANSITION",
        "FIT_AUDIT_RECORDED",
        "MORPHOTYPE_LOCKED",
        "BLUEPRINT_ISSUED",
        "APPROVAL_GRANTED",
        "DEPOSITION_STARTED",
        "DEPOSITION_PROGRESS",
        "DEPOSITION_COMPLETED",
        "SEAL_VERIFIED",
        "REFUSAL_RECORDED",
        "ERROR_RECORDED",
        "SESSION_ARCHIVED"
      ]
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "operator",
            "device",
            "system",
            "ai"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 96
        }
      }
    },
    "transformEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "session_id",
        "sequence",
        "event_type",
        "occurred_at"
      ],
      "properties": {
        "event_id": {
          "$ref": "#/$defs/eventId"
        },
        "session_id": {
          "$ref": "#/$defs/sessionId"
        },
        "sequence": {
          "type": "integer",
          "minimum": 0
        },
        "event_type": {
          "$ref": "#/$defs/transformEventType"
        },
        "occurred_at": {
          "type": "string",
          "format": "date-time"
        },
        "actor": {
          "$ref": "#/$defs/actor"
        },
        "state_before": {
          "$ref": "#/$defs/transformState"
        },
        "state_after": {
          "$ref": "#/$defs/transformState"
        },
        "payload": {
          "type": "object",
          "additionalProperties": true
        },
        "idempotency_key": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      }
    }
  }
}
